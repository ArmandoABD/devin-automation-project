# ── Devin v3 API (service user) ─────────────────────────────────────────────
# Your service-user key (starts with cog_). Required to create Devin sessions.
DEVIN_API_KEY=
# Org ID from Settings > Service Users (required for v3 org-scoped routes).
DEVIN_ORG_ID=
# Override only if needed (defaults to the v3 host).
DEVIN_BASE_URL=https://api.devin.ai/v3

# ── GitHub (the Superset fork that receives issues + PRs) ────────────────────
GITHUB_TOKEN=
GITHUB_REPO=ArmandoABD/superset_armando

# ── Behavior ────────────────────────────────────────────────────────────────
# Findings per vertical: 1 = focused demo (1 CVE + 1 code-quality issue),
# 0 = unlimited (~6 total) for a full real run.
FINDINGS_PER_VERTICAL=1
# Focused mode (true/false): narrow each vertical to one predictable task type —
# CVE dependency upgrades + SQLAlchemy .query()->select() migration.
FOCUSED_MODE=true
# Fast mode (true/false): quick, time-boxed investigation to keep the demo fast
# and cheap — no repo exploration, skip the slow full test suite, minimal change.
FAST_MODE=true
# Hard per-session ACU spend ceiling (0 = no cap). Caps cost per Devin session.
MAX_ACU_LIMIT=10
# Cap on concurrent remediation sessions per run (ACU cost guard).
MAX_SESSIONS_PER_RUN=6
# Path (inside the container) to the Superset checkout used for before/after
# scan metrics. docker-compose mounts ../superset_armando to /superset by
# default, so leave this as /superset unless you change the mount.
REPO_PATH=/superset
